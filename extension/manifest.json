{
  "manifest_version": 3,
  "name": "English Sentence Analyzer",
  "version": "1.0",
  "description": "Analyze English sentences from DailyDictation",
  "permissions": ["contextMenus", "storage"],
  "host_permissions": ["http://localhost:3000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
